{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "outDir": "dist",
    "types": [
      "node",
      "@playwright/test",
      "mocha",
      "webdriverio",
      "@wdio/globals/types"
    ]
  },
  "include": [
    "src",
    "tests",
    "playwright.config.ts , wdio/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}