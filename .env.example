# =============================================================================
# Style Workspace Automation - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# See docs/07-CONFIGURATION-REFERENCE.md for detailed descriptions of each variable.
# =============================================================================


# =============================================================================
# TARGET ENVIRONMENT — pick one profile (local + Jenkins)
# =============================================================================
#   stage-ai        →  https://stage-platform.wavemaker.ai/     (testuser1.rn@wavemaker.com)
#   stage-ai-jeevan →  https://stage-platform.wavemaker.ai/     (jeevan.inaparti@wavemaker.com)
#   stage           →  https://stage-studio.wavemakeronline.com/ (jeevan.sourab@wavemaker.com)
#   dev             →  https://dev-studio.wavemakeronline.com/   (jeevan.inaparti@wavemaker.com)
#   wmo             →  https://www.wavemakeronline.com/          (jeevan.inaparti@wavemaker.com)
#   preprod         →  https://stage-studio.wavemakeronline.com/ (jeevan.inaparti@wavemaker.com)

WM_ENV=stage-ai

# Password per env (auto-selected when you switch WM_ENV)
WM_STAGE_AI_STUDIO_PASSWORD=your-stage-ai-password
WM_STAGE_AI_JEEVAN_STUDIO_PASSWORD=your-stage-ai-jeevan-password
WM_STAGE_STUDIO_PASSWORD=your-stage-password
WM_DEV_STUDIO_PASSWORD=your-dev-password
WM_WMO_STUDIO_PASSWORD=your-wmo-password
WM_PREPROD_STUDIO_PASSWORD=your-preprod-password


# =============================================================================
# STUDIO CONFIGURATION (optional overrides — normally set by WM_ENV)
# =============================================================================

# STUDIO_BASE_URL=https://stage-platform.wavemaker.ai/
# PROJECT_ID=WMPRJ2c9180879d41cfdf019d482aa382004c
# STUDIO_PROJECT_ID=proj-63018b81-3847-4142-8862-743531a4c17f
# STUDIO_USERNAME=testuser1.rn@wavemaker.com

# Runtime Preview base URL (optional; falls back to BASE_URL or STUDIO_BASE_URL)
# RUNTIME_BASE_URL=https://stage-studio.wavemakeronline.com/

# Alternative base URL used by Playwright config
# BASE_URL=https://runtime-preview.example.com

# Path to tokens directory (optional; defaults to <repo>/Tokens)
# TOKENS_DIR=/path/to/your/tokens


# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================

# Auth method: auto-detected from STUDIO_BASE_URL when WM_ENV is set, or force manually:
#   platformdb — stage-platform.wavemaker.ai (REST login, headless CI)
#   wavemaker  — wavemakeronline.com (browser form login)
#   google     — Google OAuth (not recommended for Jenkins)
# AUTH_METHOD=platformdb

# Google OAuth credentials (used for stage-platform.wavemaker.ai)
# GOOGLE_EMAIL defaults to STUDIO_USERNAME if not set
# 2FA: On first run a visible browser opens for manual 2FA completion.
#      Session is cached (~12h) and browser profile remembers "trusted device".
#GOOGLE_EMAIL=your-email@wavemaker.com
#GOOGLE_PASSWORD=your-google-password

# TOTP secret for automated 2FA (optional — enables fully headless Google login in CI)
# Get it: Google Account → 2-Step Verification → Authenticator app → "Can't scan it?" → copy secret
# When set, 2FA codes are generated automatically; when unset, falls back to manual 2FA.
#GOOGLE_TOTP_SECRET=JBSWY3DPEHPK3PXP

# Alternative: Full Cookie header from authenticated browser session
# STUDIO_COOKIE=auth_cookie=your-cookie-value

# Alternative: API key for Studio
# STUDIO_API_KEY=your-api-key

# Some environments require Origin/Referer headers to match Studio
# STUDIO_ORIGIN=https://stage-studio.wavemakeronline.com/
# STUDIO_REFERER=https://stage-studio.wavemakeronline.com/


# =============================================================================
# API PATHS (Optional - defaults are usually correct)
# =============================================================================

# Studio login endpoint
STUDIO_LOGIN_PATH=/login/authenticate

# In-place deploy endpoint (${PROJECT_ID} is interpolated at runtime)
STUDIO_DEPLOY_PATH=studio/services/projects/${PROJECT_ID}/deployment/inplaceDeploy

# Canvas page URL path
CANVAS_PATH=s/page/Main?project-id=${PROJECT_ID}

# Preview URL path
PREVIEW_PATH=/preview

# Local RN dev preview (used by test:preview:local — no Studio credentials required)
# LOCAL_PREVIEW_URL=http://localhost:19009


# =============================================================================
# MOBILE PLATFORM
# =============================================================================

# Target mobile platform: android, ios, or both
MOBILE_PLATFORM=android

# Set to true for local Appium execution, false for BrowserStack
RUN_LOCAL=false

# Widget readiness: by default waitForWidget logs and continues if the sentinel never appears
# (after one restart + retry), so RN style commands still run. Set MOBILE_STRICT_WIDGET_WAIT=true
# to fail the test when the sentinel times out (legacy behavior).
# MOBILE_STRICT_WIDGET_WAIT=true


# =============================================================================
# MOBILE BUILD CONFIGURATION
# =============================================================================

# Base directory for mobile build artifacts
MOBILE_BUILD_DIR=./mobile-builds

# APK paths (leave empty to auto-resolve from .test-cache or mobile-builds)
# ANDROID_BASELINE_APK_PATH=/path/to/baseline/app-debug.apk
# ANDROID_ACTUAL_APK_PATH=/path/to/actual/app-debug.apk
# ANDROID_APK_PATH=/path/to/generic/app-debug.apk

# iOS IPA paths
# IOS_IPA_PATH=mobile-builds/baseline/build-out/ios/output/app-debug.ipa
# IOS_BASELINE_IPA_PATH=/path/to/baseline/app-debug.ipa

# Custom build commands (optional - override default build process)
# MOBILE_BUILD_COMMAND_ANDROID=./gradlew assembleDebug
# MOBILE_BUILD_COMMAND_IOS=xcodebuild -workspace ...


# =============================================================================
# iOS CERTIFICATES (Required for iOS builds)
# =============================================================================

# Path to .p12 certificate file
# IOS_P12_CERT_PATH=/path/to/Certificates.p12

# Path to .mobileprovision file
# IOS_PROVISION_PROFILE_PATH=/path/to/profile.mobileprovision

# Password for the .p12 certificate
# IOS_P12_PASSWORD=your-certificate-password


# =============================================================================
# BROWSERSTACK CONFIGURATION (Required for cloud testing)
# =============================================================================

# BrowserStack credentials
# Get from: https://www.browserstack.com/accounts/settings
BROWSERSTACK_USERNAME=your_browserstack_username_here
BROWSERSTACK_ACCESS_KEY=your_browserstack_access_key_here

# Device configuration
BROWSERSTACK_ANDROID_DEVICE=Samsung Galaxy S23
BROWSERSTACK_ANDROID_OS=13.0
BROWSERSTACK_IOS_DEVICE=iPhone 14
BROWSERSTACK_IOS_OS=16

# Maximum parallel BrowserStack sessions
BROWSERSTACK_MAX_INSTANCES=2

# App upload timeout (ms) and retries — increase on slow/VPN networks (default 900000 = 15 min)
# BROWSERSTACK_UPLOAD_TIMEOUT_MS=900000
# BROWSERSTACK_UPLOAD_RETRIES=3
# Parallel BrowserStack sessions (default 1 — use 2+ only if your plan allows)
# BROWSERSTACK_MAX_INSTANCES=1
# BROWSERSTACK_TEST_OBSERVABILITY=false

# iOS bundle ID for app restart on BrowserStack (optional; auto-detected via mobile:activeAppInfo when possible)
# IOS_BUNDLE_ID=com.yourcompany.yourapp

# BrowserStack app URLs (auto-populated after upload, or set manually)
# BROWSERSTACK_ANDROID_APP_URL=bs://android-app-id
# BROWSERSTACK_IOS_APP_URL=bs://ios-app-id


# =============================================================================
# LOCAL APPIUM CONFIGURATION (Required for local testing)
# =============================================================================

# Appium server connection
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723
APPIUM_PATH=/

# Android emulator configuration
LOCAL_DEVICE_NAME=Pixel 9 Pro
LOCAL_PLATFORM_VERSION=15.0

# iOS simulator configuration (falls back to LOCAL_DEVICE_NAME/VERSION if not set)
# LOCAL_IOS_DEVICE_NAME=iPhone 15
# LOCAL_IOS_PLATFORM_VERSION=17.0


# =============================================================================
# PARALLEL EXECUTION
# =============================================================================

# Number of parallel Android emulators for local parallel testing
PARALLEL_EMULATORS=5


# =============================================================================
# TEST FILTERS
# =============================================================================

# Comma-separated list of widgets to test (empty = all widgets)
# TEST_WIDGETS=button,accordion,label

# Slot verification target: canvas, preview, or both
# SLOT_VERIFY_TARGET=both


# =============================================================================
# AWS / S3 CONFIGURATION (Required for report upload)
# =============================================================================
# Reports use structure: react_native/releases/<version>/<projectname>/<platform>/<date-time>
# Example: wm-qa-automation/react_native/releases/WM-AI-Beta-2/Style Workspace/android/2025-02-24-14-30-45
#
# Platform: Playwright = canvas|preview|both, Allure = android|ios

# AWS credentials for S3 report uploads
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION=us-west-2

# S3 bucket for reports
# S3_BUCKET_NAME=wm-qa-automation

# S3 path overrides (optional)
# S3_VERSION=WM-AI-Beta-2
# S3_REPORT_VERSION=WM-AI-Beta-2
# S3_REPORT_PROJECT=Style Workspace
# S3_REPORT_PLATFORM=canvas
# S3_REPORT_DATETIME=2025-02-24-14-30-45

# Full path override (skips auto path builder when set)
# S3_PATH_PREFIX=releases/12.0.0/Style Workspace/android/2025-02-24-14-30-45
